  "keyFeatures": [
    "Automatic session sync across Claude Code, OpenCode, Hermes, and Codex",
    "Handoff briefs: original goal, decisions made, current state, and next steps",
    "Git state capture at checkpoint — shows file drift when restoring",
    "Full-text search across all session messages",
    "Local-first: no cloud, no accounts, all data stored in ~/.handshake/sessions.db",
    "Runs as a login service (launchd on macOS, systemd on Linux)",
    "MCP protocol integration — agents call Handshake as a native tool",
    "Fuzzy session title matching for fast lookup"
  ],
  "publicApiSurface": [
    "handshake setup",
